<div class="container-fluid" data-controller="territories--map territories--congregation territories--territory-list territories--territory-map territories--main-territory territories--territory-form territories--print">
  <div class="row">
    <div class="col-md-3 sidebar">
      <div class="sidebar-content">
        <h2>Territories</h2>
        <div class="filters mb-3">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <label class="form-label mb-0">Congregación</label>
            <button class="btn btn-sm btn-outline-primary"
                    data-action="click->territories--congregation#openNewForm">
              + Nueva
            </button>
          </div>
          <select class="form-select mb-2" 
                  id="congregation-filter"
                  data-territories--congregation-target="filter"
                  data-action="change->territories--congregation#change"></select>
          <label class="form-label">Estado</label>
          <select class="form-select" 
                  id="status-filter"
                  data-territories--territory-list-target="statusFilter">
            <option value="">Todos los estados</option>
            <option value="available">Disponible</option>
            <option value="assigned">Asignado</option>
            <option value="completed">Completado</option>
            <option value="returned">Devuelto</option>
          </select>
        </div>
        
        <div class="territories-list" 
             id="territories-list"
             data-territories--territory-list-target="list">
        </div>
        
        <div class="mt-3">
          <button class="btn btn-warning mb-2" 
                  style="width: 100%;" 
                  id="demarcate-main-btn"
                  data-territories--main-territory-target="demarcateBtn"
                  data-action="click->territories--main-territory#startDemarcation">
            🗺️ Demarcar Zona Principal de la Congregación
          </button>
          
          <div id="main-territory-controls" 
               style="display: none;" 
               class="mb-3 p-3 border rounded bg-light"
               data-territories--main-territory-target="controls">
            <h6 class="text-center mb-3">🏛️ <span id="congregation-name-label" 
                                                    data-territories--congregation-target="nameLabel">Zona Principal</span></h6>
            <button class="btn btn-success btn-sm w-100 mb-2" 
                    data-action="click->territories--main-territory#save">
              💾 Guardar <span id="btn-save-name">Zona Principal</span>
            </button>
            <button class="btn btn-primary btn-sm w-100 mb-2" 
                    data-action="click->territories--main-territory#edit">
              ✏️ Editar <span id="btn-edit-name">Zona Principal</span>
            </button>
            <button class="btn btn-info btn-sm w-100 mb-2" 
                    data-action="click->territories--print#printMainTerritory">
              🖨️ Imprimir <span id="btn-print-name">Zona Principal</span>
            </button>
            <button class="btn btn-danger btn-sm w-100" 
                    data-action="click->territories--main-territory#delete">
              🗑️ Eliminar <span id="btn-delete-name">Zona Principal</span>
            </button>
          </div>
          
          <button class="btn btn-primary" 
                  data-bs-toggle="modal" 
                  data-bs-target="#new-territory-modal"
                  style="display: none;">
            ✏️ Nuevo Territorio Pequeño (Modal)
          </button>
          
          <button class="btn btn-primary w-100 mb-2" 
                  id="draw-small-territory-btn"
                  data-territories--territory-form-target="drawBtn"
                  data-action="click->territories--territory-form#startDrawing">
            ✏️ Dibujar Territorio Pequeño
          </button>
          
          <div id="small-territory-controls" 
               style="display: none;" 
               class="mb-3 p-3 border rounded bg-info bg-opacity-10"
               data-territories--territory-form-target="drawingControls">
            <h6 class="text-center mb-2">✏️ Dibujando Territorio</h6>
            <div class="alert alert-info py-2 px-3 mb-3" style="font-size: 13px;">
              <strong>Instrucciones:</strong>
              <ol class="mb-0 mt-1 ps-3">
                <li>Haz clic en el botón de polígono <span class="badge bg-secondary">▢</span> en el mapa</li>
                <li>Haz clic en cada vértice del territorio</li>
                <li><strong>Doble clic</strong> o clic en el <strong>primer punto</strong> para cerrar</li>
                <li>Luego haz clic en "💾 Guardar"</li>
              </ol>
            </div>
            <button class="btn btn-success btn-sm w-100 mb-2" 
                    data-action="click->territories--territory-form#saveDrawnTerritory">
              💾 Guardar Territorio
            </button>
            <button class="btn btn-danger btn-sm w-100" 
                    data-action="click->territories--territory-form#cancelDrawing">
              ❌ Cancelar
            </button>
          </div>
          
          <button class="btn btn-success" 
                  data-action="click->territories--print#printGeneralTerritory">
            🖨️ Imprimir Territorio General
          </button>
        </div>
      </div>
    </div>
    
    <div class="col-md-9">
      <div id="map" 
           data-territories--map-target="container"
           data-territories--map-lat-value="-27.3668"
           data-territories--map-lng-value="-70.3314"
           data-territories--map-zoom-value="13"
           style="height: 100vh; width: 100%;"></div>
    </div>
  </div>
</div>

<div class="modal fade" 
     id="new-territory-modal" 
     tabindex="-1"
     data-controller="territories--territory-form"
     data-action="shown.bs.modal->territories--territory-form#modalOpened">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Crear Nuevo Territorio</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <form id="new-territory-form" data-territories--territory-form-target="form">
          <div class="mb-3">
            <label for="territory-number" class="form-label">Número del Territorio</label>
            <input type="number" 
                   class="form-control" 
                   id="territory-number" 
                   data-territories--territory-form-target="numberInput"
                   min="1"
                   placeholder="Número automático si se deja vacío">
            <div class="form-text">Se asignará el siguiente número disponible si se deja vacío</div>
          </div>
          <div class="mb-3">
            <label for="territory-name" class="form-label">Nombre del Territorio (opcional)</label>
            <input type="text" 
                   class="form-control" 
                   id="territory-name" 
                   data-territories--territory-form-target="nameInput"
                   placeholder="Ej: Zona Residencial Norte">
          </div>
          <div class="mb-3">
            <label for="territory-description" class="form-label">Descripción</label>
            <textarea class="form-control" 
                      id="territory-description" 
                      data-territories--territory-form-target="descriptionInput"
                      rows="3"
                      placeholder="Notas sobre el territorio..."></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label">Dibuja el territorio en el mapa</label>
            <div id="drawing-map" 
                 data-territories--territory-form-target="drawingMap"
                 style="height: 400px;"></div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" 
                class="btn btn-primary" 
                id="save-territory"
                data-territories--territory-form-target="saveBtn"
                data-action="click->territories--territory-form#save">Guardar</button>
      </div>
    </div>
  </div>
</div>

<!-- Modal para ver detalles del territorio -->
<div class="modal fade" id="territoryDetailModal" tabindex="-1" data-bs-backdrop="true" data-bs-keyboard="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="territoryDetailTitle">Detalle del Territorio</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" id="territoryModalCloseBtn"></button>
      </div>
      <div class="modal-body">
        <div class="row">
          <div class="col-md-6" style="display: none;">
            <h6>Información del Territorio</h6>
            <div id="territoryDetailInfo"></div>
          </div>
          <div class="col-12">
            <div id="territoryDetailMap" style="height: 500px; border: 2px solid #ddd; border-radius: 5px;"></div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" 
                class="btn btn-primary" 
                id="printTerritoryFromModal">
          🖨️ Imprimir
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" id="territoryModalCloseFooterBtn">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="new-congregation-modal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Nueva Congregación</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Nombre</label>
          <input type="text"
                 class="form-control"
                 id="new-congregation-name"
                 data-territories--congregation-target="nameInput"
                 placeholder="Ej: Congregación Norte">
        </div>
        <div class="mb-3">
          <label class="form-label">Descripción (opcional)</label>
          <textarea class="form-control"
                    id="new-congregation-description"
                    data-territories--congregation-target="descriptionInput"
                    rows="2"></textarea>
        </div>
        <div data-territories--congregation-target="formError" class="alert alert-danger d-none"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button"
                class="btn btn-primary"
                data-action="click->territories--congregation#create">
          Guardar
        </button>
      </div>
    </div>
  </div>
</div>

<%= javascript_include_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" %>
<%= stylesheet_link_tag "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" %>
<%= javascript_include_tag "https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.js" %>
<%= stylesheet_link_tag "https://unpkg.com/leaflet-draw@1.0.4/dist/leaflet.draw.css" %>

<script>
  // Handle print button and modal close functionality
  document.addEventListener('DOMContentLoaded', () => {
    const printBtn = document.getElementById('printTerritoryFromModal')
    if (printBtn) {
      printBtn.addEventListener('click', () => {
        if (window.currentDetailTerritoryId && window.printTerritory) {
          window.printTerritory(window.currentDetailTerritoryId, window.currentDetailTerritoryName)
        }
      })
    }
    
    // Function to close territory detail modal
    window.closeTerritoryDetailModal = function() {
      const modalElement = document.getElementById('territoryDetailModal')
      if (!modalElement) return
      
      // Destroy the Leaflet map instance before closing
      if (window.territoryDetailMapInstance) {
        try {
          window.territoryDetailMapInstance.remove()
          window.territoryDetailMapInstance = null
        } catch (e) {
          console.log('Error removing map on close:', e)
        }
      }
      
      // Clear map container
      const mapContainer = document.getElementById('territoryDetailMap')
      if (mapContainer) {
        mapContainer.innerHTML = ''
      }
      
      // Try Bootstrap API first
      try {
        if (typeof bootstrap !== 'undefined' && bootstrap.Modal) {
          const modalInstance = bootstrap.Modal.getInstance(modalElement)
          if (modalInstance) {
            modalInstance.hide()
          } else {
            const modal = new bootstrap.Modal(modalElement)
            modal.hide()
          }
        } else if (typeof $ !== 'undefined') {
          $(modalElement).modal('hide')
        } else {
          // Manual hide
          modalElement.classList.remove('show')
          modalElement.style.display = 'none'
          document.body.classList.remove('modal-open')
          
          // Remove backdrop
          const backdrop = document.querySelector('.modal-backdrop')
          if (backdrop) {
            backdrop.remove()
          }
        }
      } catch (error) {
        console.error('Error closing modal:', error)
        // Force close
        modalElement.classList.remove('show')
        modalElement.style.display = 'none'
        document.body.classList.remove('modal-open')
        
        // Remove backdrop
        const backdrop = document.querySelector('.modal-backdrop')
        if (backdrop) {
          backdrop.remove()
        }
      }
    }
    
    // Add click handlers for close buttons
    const closeBtn = document.getElementById('territoryModalCloseBtn')
    const closeFooterBtn = document.getElementById('territoryModalCloseFooterBtn')
    
    if (closeBtn) {
      closeBtn.addEventListener('click', window.closeTerritoryDetailModal)
    }
    
    if (closeFooterBtn) {
      closeFooterBtn.addEventListener('click', window.closeTerritoryDetailModal)
    }
    
    // Close when clicking outside the modal
    const modalElement = document.getElementById('territoryDetailModal')
    if (modalElement) {
      modalElement.addEventListener('click', (e) => {
        if (e.target === modalElement) {
          window.closeTerritoryDetailModal()
        }
      })
    }
    
    // Close with Escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        const modalElement = document.getElementById('territoryDetailModal')
        if (modalElement && modalElement.classList.contains('show')) {
          window.closeTerritoryDetailModal()
        }
      }
    })
  })
</script>
